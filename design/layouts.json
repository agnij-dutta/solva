{
  "layouts": {
    "DashboardMain": {
      "description": "Main dashboard layout with responsive grid",
      "desktop": {
        "container": {
          "maxWidth": "1536px",
          "margin": "0 auto",
          "padding": "spacing.8"
        },
        "grid": {
          "display": "grid",
          "gridTemplateColumns": "repeat(12, 1fr)",
          "gap": "spacing.6",
          "gridTemplateAreas": [
            "'header header header header header header header header header header header header'",
            "'status status status status metrics metrics metrics metrics alerts alerts alerts alerts'",
            "'progress progress progress progress progress progress chart chart chart chart chart chart'",
            "'addresses addresses addresses addresses addresses proof-feed proof-feed proof-feed proof-feed proof-feed proof-feed proof-feed'",
            "'lending lending lending lending lending lending history history history history history history'"
          ]
        },
        "sections": {
          "header": {
            "gridArea": "header",
            "marginBottom": "spacing.6"
          },
          "status": {
            "gridArea": "status"
          },
          "metrics": {
            "gridArea": "metrics"
          },
          "alerts": {
            "gridArea": "alerts"
          },
          "progress": {
            "gridArea": "progress"
          },
          "chart": {
            "gridArea": "chart"
          },
          "addresses": {
            "gridArea": "addresses"
          },
          "proofFeed": {
            "gridArea": "proof-feed"
          },
          "lending": {
            "gridArea": "lending"
          },
          "history": {
            "gridArea": "history"
          }
        }
      },
      "tablet": {
        "container": {
          "padding": "spacing.6"
        },
        "grid": {
          "gridTemplateColumns": "repeat(6, 1fr)",
          "gap": "spacing.4",
          "gridTemplateAreas": [
            "'header header header header header header'",
            "'status status status metrics metrics metrics'",
            "'alerts alerts alerts alerts alerts alerts'",
            "'progress progress progress progress progress progress'",
            "'chart chart chart chart chart chart'",
            "'addresses addresses addresses addresses addresses addresses'",
            "'proof-feed proof-feed proof-feed proof-feed proof-feed proof-feed'",
            "'lending lending lending lending lending lending'",
            "'history history history history history history'"
          ]
        }
      },
      "mobile": {
        "container": {
          "padding": "spacing.4"
        },
        "grid": {
          "gridTemplateColumns": "1fr",
          "gap": "spacing.4",
          "gridTemplateAreas": [
            "'header'",
            "'status'",
            "'alerts'",
            "'metrics'",
            "'progress'",
            "'chart'",
            "'addresses'",
            "'proof-feed'",
            "'lending'",
            "'history'"
          ]
        }
      }
    },

    "Header": {
      "description": "Dashboard header with branding and navigation",
      "desktop": {
        "container": {
          "display": "flex",
          "alignItems": "center",
          "justifyContent": "space-between",
          "padding": "spacing.4 spacing.6",
          "backgroundColor": "backgrounds.primary",
          "borderBottom": "1px solid",
          "borderColor": "borders.default"
        },
        "logo": {
          "display": "flex",
          "alignItems": "center",
          "gap": "spacing.3"
        },
        "logoIcon": {
          "width": "40px",
          "height": "40px"
        },
        "logoText": {
          "fontSize": "fontSize.2xl",
          "fontWeight": "fontWeight.bold",
          "background": "linear-gradient(135deg, primary.600, bitcoin.500)",
          "backgroundClip": "text",
          "WebkitBackgroundClip": "text",
          "WebkitTextFillColor": "transparent"
        },
        "subtitle": {
          "fontSize": "fontSize.xs",
          "color": "text.tertiary",
          "textTransform": "uppercase",
          "letterSpacing": "letterSpacing.wider"
        },
        "navigation": {
          "display": "flex",
          "gap": "spacing.6",
          "alignItems": "center"
        },
        "navItem": {
          "fontSize": "fontSize.sm",
          "fontWeight": "fontWeight.medium",
          "color": "text.secondary",
          "textDecoration": "none",
          "transition": "color duration.fast"
        },
        "navItemActive": {
          "color": "text.primary",
          "fontWeight": "fontWeight.semibold"
        },
        "actions": {
          "display": "flex",
          "gap": "spacing.3",
          "alignItems": "center"
        }
      },
      "mobile": {
        "container": {
          "flexDirection": "column",
          "gap": "spacing.4",
          "padding": "spacing.4"
        },
        "navigation": {
          "flexDirection": "column",
          "gap": "spacing.3",
          "width": "100%"
        }
      }
    },

    "StatusOverview": {
      "description": "Overview section with key status metrics",
      "layout": {
        "display": "grid",
        "gridTemplateColumns": "repeat(auto-fit, minmax(280px, 1fr))",
        "gap": "spacing.4"
      },
      "card": {
        "minHeight": "200px",
        "display": "flex",
        "flexDirection": "column",
        "justifyContent": "space-between"
      }
    },

    "ProofGenerationSection": {
      "description": "Dedicated section for proof generation UI",
      "layout": {
        "backgroundColor": "backgrounds.secondary",
        "borderRadius": "borderRadius.2xl",
        "padding": "spacing.8",
        "border": "2px solid",
        "borderColor": "borders.default"
      },
      "header": {
        "display": "flex",
        "justifyContent": "space-between",
        "alignItems": "center",
        "marginBottom": "spacing.6"
      },
      "title": {
        "fontSize": "fontSize.2xl",
        "fontWeight": "fontWeight.bold"
      },
      "controls": {
        "display": "flex",
        "gap": "spacing.3"
      }
    },

    "TwoColumnLayout": {
      "description": "Two-column layout for addresses and proof feed",
      "desktop": {
        "display": "grid",
        "gridTemplateColumns": "1fr 1fr",
        "gap": "spacing.6"
      },
      "mobile": {
        "gridTemplateColumns": "1fr",
        "gap": "spacing.4"
      }
    },

    "StickyHeader": {
      "description": "Sticky header behavior",
      "styles": {
        "position": "sticky",
        "top": 0,
        "zIndex": "zIndex.sticky",
        "backgroundColor": "backgrounds.primary",
        "backdropFilter": "blur(10px)",
        "borderBottom": "1px solid",
        "borderColor": "borders.subtle"
      }
    }
  },

  "spacing-system": {
    "section-margin": "spacing.8",
    "card-padding": "spacing.6",
    "grid-gap": "spacing.6",
    "element-gap": "spacing.4"
  },

  "responsive-breakpoints": {
    "desktop": "1024px+",
    "tablet": "768px - 1023px",
    "mobile": "0 - 767px"
  }
}
